{
  "name": "procon-sandbox",
  "workspaceFolder": "/workspaces/procon-sandbox",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile",
    "args": {
      "BASE_IMAGE": "nvidia/cuda:12.6.0-devel-ubuntu22.04",
      "USERNAME": "dev",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "runArgs": [
    "--gpus",   "all",
    "--device", "/dev/dxg",
    "--env",    "DISPLAY=${localEnv:DISPLAY}",
    "--env",    "XAUTHORITY=/home/dev/.Xauthority",
    "--env",    "NVIDIA_VISIBLE_DEVICES=all",
    "--env",    "NVIDIA_DRIVER_CAPABILITIES=compute,graphics,utility",
    "--volume", "/tmp/.X11-unix:/tmp/.X11-unix:ro",
    "--volume", "${localEnv:HOME}/.Xauthority:/home/dev/.Xauthority:ro",
    "--mount",  "type=bind,src=/usr/lib/wsl/lib,dst=/usr/lib/wsl/lib,ro"
  ],
  "containerEnv": {
    "WAYLAND_DISPLAY": "",
    "WINIT_UNIX_BACKEND": "x11",
    "XDG_RUNTIME_DIR": "/tmp/xdg-runtime"
  },
  "remoteUser": "dev",
  "postCreateCommand": "bash -lc \"if ! command -v rustc >/dev/null 2>&1; then curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y; fi && source $HOME/.cargo/env && rustup default stable && rustup component add rustfmt clippy && cargo --version\"",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "mhutchie.git-graph",
        "hediet.vscode-drawio",
        "GitHub.codespaces",
        "GitHub.vscode-pull-request-github",
        "rust-lang.rust-analyzer"
      ],
      "settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "/bin/bash"
					}
				},
        "files.autoSave": "onFocusChange",
        "git-graph.repository.showTags": true,
        "git.autofetch": "all",
        "git.autofetchPeriod": 180,
				"terminal.integrated.env.linux": {
					// "PATH": "/home/dev/.cargo/bin:${env:PATH}",
					"WAYLAND_DISPLAY": "",
					"WINIT_UNIX_BACKEND": "x11"
				},
        "[markdown]": {
          "editor.wordWrap": "off"
        }
      }
    }
  }
}
